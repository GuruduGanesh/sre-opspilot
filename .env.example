# Copy this file to .env. Never commit .env or either provider key.
# Use OpenRouter with GPT-5.6 for local test runs, then switch to direct OpenAI
# for the final verified demo recording.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.6-luna
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_REASONING_EFFORT=medium

# Optional: set only after recording your account-specific pricing assumptions.
MODEL_PRICE_INPUT_PER_MILLION=
MODEL_PRICE_OUTPUT_PER_MILLION=

# Local demo defaults.
OPS_PILOT_DB_PATH=artifacts/opspilot.db
OPS_PILOT_PROMETHEUS_URL=http://127.0.0.1:9090
OPS_PILOT_DEMO_CONTROLS_ENABLED=true
# Explicit local rehearsal fallback. It creates a deterministic report from
# persisted evidence and is visibly labelled as not GPT-5.6. Keep false for
# final OpenAI validation and recording.
OPS_PILOT_SIMULATION_INVESTIGATION_ENABLED=false
