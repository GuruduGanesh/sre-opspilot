# Server-side settings. Copy to .env locally; never commit credentials.
OPS_PILOT_DB_PATH=./artifacts/opspilot.db
OPS_PILOT_DEMO_NAMESPACE=opspilot-demo
# Leave blank for the local controlled demo. Set a strong secret before any hosted
# judge path and pass it to scripts/send-p1-alert.ps1 with -Secret.
OPS_PILOT_ALERT_SHARED_SECRET=

# Reserved for the GPT-5.6 workflow phase. No API key is needed for the current
# ingress, evidence, safety, or simulation foundation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
OPENAI_REASONING_EFFORT=medium
# Optional, dated local pricing snapshot for model-smoke.ps1 cost estimates.
MODEL_PRICE_INPUT_PER_MILLION=
MODEL_PRICE_OUTPUT_PER_MILLION=
